{
  "name": "pickapath-syntax",
  "displayName": "PickaPath",
  "description": "Syntax highlighting and validation for PickaPath interactive fiction",
  "version": "0.0.1",
  "license": "SEE LICENSE IN LICENSE",
  "publisher": "PickAPath",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PickAPathGames/PickAPath-extension.git"
  },
  "bugs": {
    "url": "https://github.com/PickAPathGames/PickAPath-extension/issues"
  },
  "homepage": "https://github.com/PickAPathGames/PickAPath-extension#readme",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:pickapath",
    "onCommand:pickapath.runValidator"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "languages": [
      {
        "id": "pickapath",
        "aliases": [
          "PickaPath",
          "pickapath"
        ],
        "extensions": [
          ".pap",
          ".txt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pickapath",
        "scopeName": "source.pickapath",
        "path": "./syntaxes/pickapath.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "pickapath.runValidator",
        "title": "PickaPath: Run Validator"
      },
      {
        "command": "pickapath.toggleIgnore",
        "title": "PickaPath: Toggle -ignore"
      }
    ],
    "keybindings": [
      {
        "command": "pickapath.runValidator",
        "key": "ctrl+shift+v",
        "when": "editorLangId == pickapath"
      },
      {
        "key": "ctrl+/",
        "command": "pickapath.toggleIgnore",
        "when": "editorLangId == pickapath"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.3.3"
  }
}
